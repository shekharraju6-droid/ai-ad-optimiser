# Example environment variables for Railway
# Copy these into Railway Dashboard → Variables

# JWT secret for auth tokens
ADOPTIMA_JWT_SECRET=change-me-to-a-long-random-string

# Database: Supabase PostgreSQL (recommended for Railway)
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# Use the Supabase Transaction Pooler URL, not the direct 5432 URL.
# If set, this takes priority over SQLite.
DATABASE_URL=

# SQLite fallback (local dev only)
ADOPTIMA_DB_PATH=/app/data/adoptima.db

# Host and port (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8000

# Public base URL for onboarding setup links
ADOPTIMA_PUBLIC_BASE_URL=https://your-railway-domain.up.railway.app

# Optional: disable scheduler in dev or keep enabled
# ADOPTIMA_SCHEDULER_ENABLED=true
